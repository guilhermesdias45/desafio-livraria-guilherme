<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="
        https://jakarta.ee/xml/ns/persistence
        https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="desafio_livraria" transaction-type="RESOURCE_LOCAL">
        <class>vc.com.programar.entidade.Livro</class>
        <class>vc.com.programar.entidade.Venda</class>
        <class>vc.com.programar.entidade.Impresso</class>
        <class>vc.com.programar.entidade.Eletronico</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver" />
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/desafio_livraria?serverTimezone=UTC" />
            <property name="jakarta.persistence.jdbc.user"
                      value="<seu-usuario-banco-aqui>" />
            <property name="jakarta.persistence.jdbc.password"
                      value="<sua-senha-aqui>" />

            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect" />
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>
            <property name="hibernate.hbm2ddl.auto" value="create-drop" />

            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.format_sql" value="true" />

        </properties>
    </persistence-unit>

</persistence>
